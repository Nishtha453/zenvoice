PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
RESEND_API_KEY=
EMAIL_FROM=Zenvoice <invoices@your-verified-domain.com>

